{
  "info": {
    "_postman_id": "a1b2c3d4-fila-zero-api",
    "name": "FilaZero API",
    "description": "Coleção dos endpoints da API FilaZero.\n\n**Local:** `baseUrl` = `http://localhost:8080` (sem prefixo de stage).\n\n**AWS Lambda (HTTP API):** use `baseUrl` = `https://{api-id}.execute-api.{região}.amazonaws.com/prod` — o prefixo `/prod` é aplicado automaticamente aos controllers em produção (`FILAZERO_HTTP_API_STAGE_PREFIX`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "unitId", "value": "1" },
    { "key": "patientId", "value": "" },
    { "key": "triageId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "phone", "value": "11999999999" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "POST identify-or-create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"cpf\": \"12345678901\",\n  \"birthDate\": \"1990-01-15\"\n}"
            },
            "url": "{{baseUrl}}/api/patients/identify-or-create"
          }
        }
      ]
    },
    {
      "name": "Triages",
      "item": [
        {
          "name": "POST evaluate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"isUrgent\": false,\n  \"symptomDescription\": \"Febre leve\"\n}"
            },
            "url": "{{baseUrl}}/api/triages/evaluate"
          }
        },
        {
          "name": "GET by-phone",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/triages/by-phone?phone={{phone}}"
          }
        }
      ]
    },
    {
      "name": "Queue",
      "item": [
        {
          "name": "POST create ticket",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"triageId\": \"{{triageId}}\",\n  \"unitId\": {{unitId}}\n}"
            },
            "url": "{{baseUrl}}/api/queue/tickets"
          }
        },
        {
          "name": "GET ticket by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/queue/tickets/{{ticketId}}"
          }
        },
        {
          "name": "POST checkin",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/queue/tickets/{{ticketId}}/checkin"
          }
        },
        {
          "name": "POST call",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/queue/tickets/{{ticketId}}/call"
          }
        },
        {
          "name": "POST finish (DONE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"outcome\": \"DONE\"\n}"
            },
            "url": "{{baseUrl}}/api/queue/tickets/{{ticketId}}/finish"
          }
        },
        {
          "name": "POST finish (NO_SHOW)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"outcome\": \"NO_SHOW\"\n}"
            },
            "url": "{{baseUrl}}/api/queue/tickets/{{ticketId}}/finish"
          }
        },
        {
          "name": "GET list by unit + status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/queue/units/{{unitId}}/tickets?status=CHECKED_IN"
          }
        },
        {
          "name": "GET panel (waiting + checkedIn + called)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/queue/units/{{unitId}}/panel"
          }
        },
        {
          "name": "GET metrics (today)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/queue/units/{{unitId}}/metrics"
          }
        },
        {
          "name": "GET metrics (date)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/queue/units/{{unitId}}/metrics?date=2026-04-07"
          }
        }
      ]
    }
  ]
}
